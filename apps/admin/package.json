{
  "name": "@silonya/admin",
  "version": "0.0.0",
  "private": true,
  "description": "SILONYA internal admin dashboard (ADMIN_PANEL.md)",
  "scripts": {
    "dev": "dotenv -e ../../.env -- next dev --turbopack --port 3001",
    "build": "dotenv -e ../../.env -- next build",
    "start": "dotenv -e ../../.env -- next start --port 3001",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo .next node_modules"
  },
  "dependencies": {
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.1.0",
    "@silonya/ui": "workspace:*",
    "@silonya/utils": "workspace:*",
    "@silonya/api": "workspace:*",
    "@silonya/auth": "workspace:*",
    "@silonya/database": "workspace:*",
    "@tanstack/react-query": "^5.62.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "lucide-react": "^0.469.0",
    "server-only": "^0.0.1",
    "superjson": "^2.2.2",
    "zod": "^3.24.1"
  },
  "optionalDependencies": {
    "@node-rs/argon2-linux-x64-gnu": "^2.0.2"
  },
  "devDependencies": {
    "@silonya/config": "workspace:*",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.17.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
