// SILONYA — Prisma schema
// Source of truth for structure: DATABASE_ARCHITECTURE.md
// This file defines the data model only. No seed data, no queries, no
// business logic — those are introduced in a later phase.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  // No custom `output` — deliberately generates into its default
  // node_modules-resolved location (@prisma/client). A custom output path
  // (this used to be "../generated/client") breaks Next.js's
  // `serverExternalPackages` on Vercel: that config only externalizes
  // imports whose *resolved file path* contains "node_modules/<pkg>/" (see
  // next's build/webpack-config.js — it's a literal substring regex on the
  // resolved path), so a generated client living outside node_modules can
  // never match it regardless of what name is listed. Without a working
  // external, `@silonya/database` (a transpilePackages entry) gets its
  // Prisma client bundled directly into the app's webpack chunks, which
  // breaks the query engine's own relative-to-itself binary lookup at
  // runtime — the actual cause of a real "Query Engine for runtime
  // rhel-openssl-3.0.x" production outage, empirically confirmed via
  // Vercel deploy logs, not a guess.
  //
  // "native" alone isn't reliable on Vercel either: the build container's
  // own reported platform can differ from the actual Lambda runtime's, so
  // "native" generates whatever engine the *build* machine happens to be,
  // not necessarily what the deployed function needs
  // (https://pris.ly/d/engine-not-found-nextjs). rhel-openssl-3.0.x is
  // what Vercel's Node.js Lambda runtime actually needs; keeping "native"
  // too so local dev (Windows/macOS) still works.
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [citext]
}

// ─────────────────────────────────────────────────────────────────────────
// 3.1 Identity & Access — DATABASE_ARCHITECTURE.md §3.1, AUTHENTICATION.md
// ─────────────────────────────────────────────────────────────────────────

enum AuthProvider {
  credentials
  google
  apple
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique @db.Citext
  passwordHash     String?   @map("password_hash")
  firstName        String?   @map("first_name")
  lastName         String?   @map("last_name")
  phone            String?
  emailVerifiedAt  DateTime? @map("email_verified_at")
  marketingOptIn   Boolean   @default(false) @map("marketing_opt_in")
  defaultAddressId String?   @map("default_address_id") // superseded by the split fields below; kept for backward compatibility, unused by application code

  defaultShippingAddressId String? @map("default_shipping_address_id")
  defaultBillingAddressId  String? @map("default_billing_address_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  defaultShippingAddress Address? @relation("UserDefaultShippingAddress", fields: [defaultShippingAddressId], references: [id], onDelete: SetNull)
  defaultBillingAddress  Address? @relation("UserDefaultBillingAddress", fields: [defaultBillingAddressId], references: [id], onDelete: SetNull)

  authIdentities      AuthIdentity[]
  sessions            Session[]
  addresses           Address[]
  carts               Cart[]
  orders              Order[]
  reviews             Review[]
  wishlist            Wishlist?
  discountRedemptions DiscountRedemption[]
  verificationTokens  VerificationToken[]
  discountEligibility DiscountEligibility[]
  recentlyViewed      RecentlyViewed[]

  @@index([createdAt])
  @@map("users")
}

enum VerificationTokenType {
  password_reset
  email_verification
}

/**
 * Single-use, time-limited tokens for password reset and email verification
 * (AUTHENTICATION.md §2.3, §2.4) — one table for both since the shape is
 * identical (opaque random token, hashed at rest via the same
 * generateRefreshToken/hashRefreshToken pair packages/auth already uses for
 * customer sessions, never the raw value stored). `usedAt` is what makes
 * single-use enforceable; a bare signed JWT couldn't do that without a
 * separate revocation list anyway, so this is no heavier than the
 * alternative.
 */
model VerificationToken {
  id        String                @id @default(uuid())
  userId    String                @map("user_id")
  type      VerificationTokenType
  tokenHash String                @unique @map("token_hash")
  expiresAt DateTime              @map("expires_at")
  usedAt    DateTime?             @map("used_at")

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("verification_tokens")
}

/**
 * Client-adjacent but persisted per-account so "recently viewed" survives
 * across devices once logged in (CUSTOMER_EXPERIENCE — guests still get a
 * local-only version via localStorage, matching the pre-account cart/
 * wishlist pattern; this table is additive for signed-in users only).
 */
model RecentlyViewed {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  viewedAt  DateTime @default(now()) @map("viewed_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("recently_viewed")
}

model AuthIdentity {
  id                String       @id @default(uuid())
  userId            String       @map("user_id")
  provider          AuthProvider
  providerAccountId String       @map("provider_account_id")

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("auth_identities")
}

model Session {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  refreshTokenHash String    @unique @map("refresh_token_hash")
  userAgent        String?   @map("user_agent")
  ipAddress        String?   @map("ip_address")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Address {
  id          String  @id @default(uuid())
  userId      String? @map("user_id")
  // Recipient name for this specific address — not on User, since a guest
  // checkout (no User row at all) or a logged-in customer shipping to
  // someone else both need it captured per-address, not per-account.
  fullName    String?
  line1       String
  line2       String?
  city        String
  region      String?
  // Optional (CHECKOUT_ARCHITECTURE — Pakistan launch): many Pakistani
  // addresses are given without a postal code in practice.
  postalCode  String? @map("postal_code")
  countryCode String  @map("country_code") @db.Char(2)
  phone       String?
  isDefault   Boolean @default(false) @map("is_default")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user                    User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  ordersAsShipping        Order[] @relation("OrderShippingAddress")
  ordersAsBilling         Order[] @relation("OrderBillingAddress")
  defaultForShippingUsers User[]  @relation("UserDefaultShippingAddress")
  defaultForBillingUsers  User[]  @relation("UserDefaultBillingAddress")

  @@index([userId])
  @@map("addresses")
}

// ─────────────────────────────────────────────────────────────────────────
// Admin identity & RBAC — AUTHENTICATION.md §3–5
// ─────────────────────────────────────────────────────────────────────────

model AdminUser {
  id                  String    @id @default(uuid())
  email               String    @unique @db.Citext
  passwordHash        String    @map("password_hash")
  firstName           String?   @map("first_name")
  lastName            String?   @map("last_name")
  roleId              String    @map("role_id")
  twoFactorSecret     String?   @map("two_factor_secret")
  twoFactorEnabled    Boolean   @default(false) @map("two_factor_enabled")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deactivatedAt DateTime? @map("deactivated_at")

  role              Role               @relation(fields: [roleId], references: [id], onDelete: Restrict)
  auditLogEntries   AuditLogEntry[]
  sessions          AdminSession[]
  orderNotes        OrderNote[]
  orderStatusEvents OrderStatusEvent[]

  @@index([roleId])
  @@map("admin_users")
}

// Mirrors User/Session but scoped to AdminUser — kept as a separate table
// (not a shared polymorphic session table) so a customer session can never
// be confused with an admin session, per AUTHENTICATION.md §1's "two
// separate identity domains" principle. Shorter TTL enforced in
// packages/auth, not at the schema level.
model AdminSession {
  id               String    @id @default(uuid())
  adminUserId      String    @map("admin_user_id")
  refreshTokenHash String    @unique @map("refresh_token_hash")
  userAgent        String?   @map("user_agent")
  ipAddress        String?   @map("ip_address")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")

  createdAt DateTime @default(now()) @map("created_at")

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@map("admin_sessions")
}

model Role {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  adminUsers  AdminUser[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid())
  key         String  @unique // e.g. "orders:write"
  description String?

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AuditLogEntry {
  id          String  @id @default(uuid())
  adminUserId String  @map("admin_user_id")
  action      String
  targetType  String  @map("target_type")
  targetId    String  @map("target_id")
  metadata    Json?
  ipAddress   String? @map("ip_address")

  createdAt DateTime @default(now()) @map("created_at")

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Restrict)

  @@index([adminUserId])
  @@index([targetType, targetId])
  @@map("audit_log_entries")
}

// ─────────────────────────────────────────────────────────────────────────
// 3.2 Catalog — DATABASE_ARCHITECTURE.md §3.2, PRODUCT_SYSTEM.md
// ─────────────────────────────────────────────────────────────────────────

enum ProductStatus {
  draft
  active
  archived
}

model Product {
  id             String        @id @default(uuid())
  slug           String        @unique
  name           String
  description    String?
  status         ProductStatus @default(draft)
  basePrice      Int           @map("base_price") // minor units
  currency       String        @default("PKR") @db.Char(3)
  brandId        String?       @map("brand_id") // reserved for future multi-brand
  seoTitle       String?       @map("seo_title")
  seoDescription String?       @map("seo_description")
  publishedAt    DateTime?     @map("published_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  options        ProductOption[]
  variants       ProductVariant[]
  media          ProductMedia[]
  collections    ProductCollection[]
  categories     ProductCategory[]
  reviews        Review[]
  recentlyViewed RecentlyViewed[]

  @@index([status])
  @@map("products")
}

model ProductOption {
  id        String @id @default(uuid())
  productId String @map("product_id")
  name      String // e.g. "Size", "Color"
  position  Int    @default(0)

  product Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  values  ProductOptionValue[]

  @@index([productId])
  @@map("product_options")
}

model ProductOptionValue {
  id              String @id @default(uuid())
  productOptionId String @map("product_option_id")
  value           String // e.g. "Black", "M"
  position        Int    @default(0)

  productOption ProductOption        @relation(fields: [productOptionId], references: [id], onDelete: Cascade)
  variants      VariantOptionValue[]

  @@index([productOptionId])
  @@map("product_option_values")
}

model ProductVariant {
  id             String  @id @default(uuid())
  productId      String  @map("product_id")
  sku            String  @unique
  price          Int? // overrides Product.basePrice if set (minor units)
  compareAtPrice Int?    @map("compare_at_price")
  weightGrams    Int?    @map("weight_grams")
  barcode        String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product       Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  optionValues  VariantOptionValue[]
  media         ProductMedia[]
  inventory     Inventory[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  wishlistItems WishlistItem[]

  @@index([productId])
  @@map("product_variants")
}

model VariantOptionValue {
  variantId            String @map("variant_id")
  productOptionValueId String @map("product_option_value_id")

  variant            ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  productOptionValue ProductOptionValue @relation(fields: [productOptionValueId], references: [id], onDelete: Cascade)

  @@id([variantId, productOptionValueId])
  @@map("variant_option_values")
}

model ProductMedia {
  id        String  @id @default(uuid())
  productId String  @map("product_id")
  variantId String? @map("variant_id")
  url       String
  altText   String  @map("alt_text")
  position  Int     @default(0)

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@map("product_media")
}

model Category {
  id       String  @id @default(uuid())
  name     String
  slug     String  @unique
  parentId String? @map("parent_id")

  parent   Category?         @relation("CategoryToCategory", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[]        @relation("CategoryToCategory")
  products ProductCategory[]

  @@index([parentId])
  @@map("categories")
}

model Collection {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String?

  products ProductCollection[]

  @@map("collections")
}

model ProductCollection {
  productId    String @map("product_id")
  collectionId String @map("collection_id")

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
  @@map("product_collections")
}

model ProductCategory {
  productId  String @map("product_id")
  categoryId String @map("category_id")

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@map("product_categories")
}

// ─────────────────────────────────────────────────────────────────────────
// 3.3 Inventory — DATABASE_ARCHITECTURE.md §3.3, PRODUCT_SYSTEM.md §4
// ─────────────────────────────────────────────────────────────────────────

model Warehouse {
  id          String  @id @default(uuid())
  name        String
  countryCode String  @map("country_code") @db.Char(2)
  isDefault   Boolean @default(false) @map("is_default")

  inventory Inventory[]

  @@map("warehouses")
}

model Inventory {
  id               String @id @default(uuid())
  variantId        String @map("variant_id")
  warehouseId      String @map("warehouse_id")
  quantityOnHand   Int    @default(0) @map("quantity_on_hand")
  quantityReserved Int    @default(0) @map("quantity_reserved")

  updatedAt DateTime @updatedAt @map("updated_at")

  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  @@unique([variantId, warehouseId])
  @@map("inventory")
}

// ─────────────────────────────────────────────────────────────────────────
// 3.4 Cart — DATABASE_ARCHITECTURE.md §3.4
// ─────────────────────────────────────────────────────────────────────────

model Cart {
  id           String   @id @default(uuid())
  userId       String?  @map("user_id")
  sessionToken String?  @map("session_token")
  currency     String   @default("PKR") @db.Char(3)
  expiresAt    DateTime @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([userId])
  @@index([sessionToken])
  @@map("carts")
}

model CartItem {
  id                String @id @default(uuid())
  cartId            String @map("cart_id")
  variantId         String @map("variant_id")
  quantity          Int
  unitPriceSnapshot Int    @map("unit_price_snapshot")

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([cartId])
  @@map("cart_items")
}

// ─────────────────────────────────────────────────────────────────────────
// 3.5 Orders & Payments — DATABASE_ARCHITECTURE.md §3.5, ORDER_MANAGEMENT.md,
// PAYMENT_ARCHITECTURE.md
// ─────────────────────────────────────────────────────────────────────────

enum OrderStatus {
  pending_payment
  payment_failed
  paid
  processing
  shipped
  delivered
  cancelled
  returned
  refunded
  partially_refunded
}

/** Pakistan launch supports exactly these two (PAYMENT_ARCHITECTURE.md) — "online" is a real gateway integration deferred to a later phase; selecting it in the storefront is currently blocked client-side with a "coming soon" message rather than reachable through checkout.createIntent at all. */
enum OrderPaymentMethod {
  cod
  online
}

enum OrderEventTrigger {
  customer
  admin
  system
  webhook
}

model Order {
  id          String      @id @default(uuid())
  orderNumber String      @unique @map("order_number")
  userId      String?     @map("user_id")
  guestEmail  String?     @map("guest_email")
  status      OrderStatus @default(pending_payment)

  subtotal      Int    @map("subtotal")
  shippingTotal Int    @default(0) @map("shipping_total")
  taxTotal      Int    @default(0) @map("tax_total")
  discountTotal Int    @default(0) @map("discount_total")
  giftCardTotal Int    @default(0) @map("gift_card_total")
  grandTotal    Int    @map("grand_total")
  currency      String @default("PKR") @db.Char(3)

  // Pakistan checkout redesign — how the order was placed and how it ships.
  // "online" never reaches this table in practice yet (blocked client-side
  // with a "coming soon" message before checkout.createIntent is ever
  // called for it); the enum exists so the column is ready the day a real
  // gateway is wired up, without another migration.
  paymentMethod  OrderPaymentMethod @default(cod) @map("payment_method")
  shippingMethod String             @default("standard") @map("shipping_method")
  // Customer-entered note at checkout ("leave with the guard", "call before
  // delivery") — distinct from OrderNote below, which is admin/CS-authored
  // internal operational notes.
  customerNote   String?            @map("customer_note")

  shippingAddressId String  @map("shipping_address_id")
  billingAddressId  String  @map("billing_address_id")
  discountId        String? @map("discount_id")

  // ADMIN_PANEL.md §4.2 — fulfillment status updates carry a tracking
  // number; kept directly on Order (rather than only in OrderStatusEvent's
  // free-text note) since it needs to stay visible/queryable regardless of
  // how many further status transitions happen afterward.
  trackingNumber String? @map("tracking_number")
  carrier        String? @map("carrier")

  placedAt  DateTime? @map("placed_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user            User?     @relation(fields: [userId], references: [id], onDelete: Restrict)
  shippingAddress Address   @relation("OrderShippingAddress", fields: [shippingAddressId], references: [id], onDelete: Restrict)
  billingAddress  Address   @relation("OrderBillingAddress", fields: [billingAddressId], references: [id], onDelete: Restrict)
  discount        Discount? @relation(fields: [discountId], references: [id], onDelete: SetNull)

  items                OrderItem[]
  statusEvents         OrderStatusEvent[]
  payment              Payment?
  discountRedemptions  DiscountRedemption[]
  notes                OrderNote[]
  giftCardTransactions GiftCardTransaction[]

  @@index([userId])
  @@index([status])
  // Phase 10+11 analytics/reports (admin-analytics.ts, services/reports.ts)
  // filter on exactly this pair — status IN (...) AND placed_at >= X — on
  // every dashboard load; without it those queries fall back to a full
  // table scan as order volume grows.
  @@index([status, placedAt])
  @@map("orders")
}

/**
 * Internal staff notes (ADMIN_PANEL.md §4.2) — append-only, never customer-visible, matches the OrderStatusEvent audit-trail pattern rather than a single overwritable text field.
 */
model OrderNote {
  id          String @id @default(uuid())
  orderId     String @map("order_id")
  adminUserId String @map("admin_user_id")
  body        String

  createdAt DateTime @default(now()) @map("created_at")

  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@map("order_notes")
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String @map("order_id")
  variantId String @map("variant_id")

  productNameSnapshot  String @map("product_name_snapshot")
  variantLabelSnapshot String @map("variant_label_snapshot")
  skuSnapshot          String @map("sku_snapshot")

  unitPrice Int @map("unit_price")
  quantity  Int
  lineTotal Int @map("line_total")

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@map("order_items")
}

model OrderStatusEvent {
  id          String            @id @default(uuid())
  orderId     String            @map("order_id")
  status      OrderStatus
  note        String?
  triggeredBy OrderEventTrigger @map("triggered_by")
  adminUserId String?           @map("admin_user_id")

  createdAt DateTime @default(now()) @map("created_at")

  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  adminUser AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("order_status_events")
}

enum PaymentStatus {
  requires_action
  processing
  succeeded
  failed
  refunded
  partially_refunded
}

model Payment {
  id                    String        @id @default(uuid())
  orderId               String        @unique @map("order_id")
  stripePaymentIntentId String        @unique @map("stripe_payment_intent_id")
  status                PaymentStatus @default(requires_action)
  amount                Int
  currency              String        @default("PKR") @db.Char(3)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Restrict)
  refunds Refund[]

  @@map("payments")
}

model Refund {
  id             String  @id @default(uuid())
  paymentId      String  @map("payment_id")
  stripeRefundId String  @unique @map("stripe_refund_id")
  amount         Int
  reason         String?

  createdAt DateTime @default(now()) @map("created_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Restrict)

  @@index([paymentId])
  @@map("refunds")
}

// ─────────────────────────────────────────────────────────────────────────
// 3.6 Promotions — DATABASE_ARCHITECTURE.md §3.6, ORDER_MANAGEMENT.md §8
// ─────────────────────────────────────────────────────────────────────────

enum DiscountType {
  percentage
  fixed_amount
  free_shipping
}

model Discount {
  id              String       @id @default(uuid())
  code            String?      @unique
  type            DiscountType
  value           Int
  startsAt        DateTime?    @map("starts_at")
  endsAt          DateTime?    @map("ends_at")
  usageLimit      Int?         @map("usage_limit")
  perUserLimit    Int?         @map("per_user_limit")
  minimumSubtotal Int?         @map("minimum_subtotal")

  createdAt DateTime @default(now()) @map("created_at")

  orders      Order[]
  redemptions DiscountRedemption[]
  eligibility DiscountEligibility[]

  @@map("discounts")
}

/**
 * Customer-specific coupons — presence of any row here restricts the
 * discount to those users; a Discount with no eligibility rows stays
 * available to everyone (unchanged existing behavior). Automatic discounts
 * (PROMOTIONS — `code: null`) are applied at checkout without a code, per
 * DATABASE_ARCHITECTURE.md's original "null = automatic discount" design.
 */
model DiscountEligibility {
  discountId String @map("discount_id")
  userId     String @map("user_id")

  discount Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([discountId, userId])
  @@map("discount_eligibility")
}

model DiscountRedemption {
  id         String  @id @default(uuid())
  discountId String  @map("discount_id")
  userId     String? @map("user_id")
  orderId    String  @map("order_id")

  createdAt DateTime @default(now()) @map("created_at")

  discount Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([discountId, userId])
  @@map("discount_redemptions")
}

// ─────────────────────────────────────────────────────────────────────────
// 3.7 Reviews & Wishlist — DATABASE_ARCHITECTURE.md §3.7, PRODUCT_SYSTEM.md §8
// ─────────────────────────────────────────────────────────────────────────

enum ReviewStatus {
  pending
  published
  rejected
}

model Review {
  id        String       @id @default(uuid())
  productId String       @map("product_id")
  userId    String       @map("user_id")
  orderId   String       @map("order_id")
  rating    Int
  title     String?
  body      String
  status    ReviewStatus @default(pending)

  createdAt DateTime @default(now()) @map("created_at")

  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  media   ReviewMedia[]

  @@index([productId])
  @@map("reviews")
}

/**
 * Review images (SHOPPING FEATURES — "review images architecture") — mirrors ProductMedia's shape; upload reuses the same signed-Cloudinary-upload pattern as admin product media (media.ts), stubbed until real credentials exist.
 */
model ReviewMedia {
  id       String @id @default(uuid())
  reviewId String @map("review_id")
  url      String
  position Int    @default(0)

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("review_media")
}

model Wishlist {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WishlistItem[]

  @@map("wishlists")
}

model WishlistItem {
  id            String  @id @default(uuid())
  wishlistId    String  @map("wishlist_id")
  variantId     String  @map("variant_id")
  // "Save for later" (SHOPPING FEATURES) reuses the wishlist bucket rather
  // than a parallel table — moving a cart line to "saved for later" is
  // exactly "remove from cart, add here with this flag set."
  savedForLater Boolean @default(false) @map("saved_for_later")

  createdAt DateTime @default(now()) @map("created_at")

  wishlist Wishlist       @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  variant  ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, variantId])
  @@map("wishlist_items")
}

// ─────────────────────────────────────────────────────────────────────────
// 3.8 Gift Cards — PROMOTIONS. Stored-value balance, separate from
// Discount (a Discount reduces a line-item price computation; a gift
// card is redeemed against the grand total like a partial payment method
// — DATABASE_ARCHITECTURE.md §1's "money is always integers" applies here
// too). GiftCardTransaction is the append-only ledger; GiftCard.currentBalance
// is a denormalized running total kept in sync inside the same transaction
// as every ledger write, never computed ad hoc.
// ─────────────────────────────────────────────────────────────────────────

enum GiftCardTransactionType {
  issued
  redeemed
  refunded
  adjusted
}

model GiftCard {
  id             String    @id @default(uuid())
  code           String    @unique
  initialBalance Int       @map("initial_balance")
  currentBalance Int       @map("current_balance")
  currency       String    @default("PKR") @db.Char(3)
  issuedToEmail  String?   @map("issued_to_email")
  expiresAt      DateTime? @map("expires_at")
  isActive       Boolean   @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")

  transactions GiftCardTransaction[]

  @@map("gift_cards")
}

model GiftCardTransaction {
  id         String                  @id @default(uuid())
  giftCardId String                  @map("gift_card_id")
  orderId    String?                 @map("order_id")
  type       GiftCardTransactionType
  amount     Int

  createdAt DateTime @default(now()) @map("created_at")

  giftCard GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
  order    Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([giftCardId])
  @@map("gift_card_transactions")
}

// ─────────────────────────────────────────────────────────────────────────
// 3.9 Content (CMS) — ADMIN_PANEL.md §4.6. "Lightweight structured-content
// editor... not a general-purpose page builder": every model here is a
// fixed set of typed fields rendered through an existing, designed
// component (Hero, PromoBanner, EditorialSection), never a freeform
// block/drag-and-drop schema.
// ─────────────────────────────────────────────────────────────────────────

enum ContentBlockType {
  hero
  promo_banner
  editorial
}

/**
 * One row per type (`type` is unique) — the homepage has exactly one hero,
 * one promo banner, one editorial section (apps/web/app/page.tsx's fixed
 * structure, unchanged); this table replaces lib/homepage-content.ts's
 * hardcoded exports with the same shape, admin-editable. Unused fields for
 * a given type stay null (e.g. promo_banner only uses `body` as its
 * message) rather than three near-duplicate tables for three singletons.
 */
model ContentBlock {
  id         String           @id @default(uuid())
  type       ContentBlockType @unique
  eyebrow    String?
  heading    String?
  subheading String?
  body       String?
  imageUrl   String?
  imageAlt   String?
  ctaLabel   String?
  ctaHref    String?
  isActive   Boolean          @default(true)

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("content_blocks")
}

enum PageType {
  editorial
  lookbook
  static_page
}

enum PageStatus {
  draft
  published
}

/**
 * Editorial/lookbook/static pages (About, Shipping & Returns, Size Guide, ...) — one fixed template per type (image + eyebrow + heading + body + optional CTA), not a page builder.
 */
model Page {
  id             String     @id @default(uuid())
  slug           String     @unique
  type           PageType
  title          String
  heroImageUrl   String?    @map("hero_image_url")
  heroImageAlt   String?    @map("hero_image_alt")
  body           String
  seoTitle       String?    @map("seo_title")
  seoDescription String?    @map("seo_description")
  status         PageStatus @default(draft)
  publishedAt    DateTime?  @map("published_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("pages")
}

model FaqItem {
  id       String  @id @default(uuid())
  category String?
  question String
  answer   String
  position Int     @default(0)
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("faq_items")
}

/**
 * Replaces lib/nav-data.ts's hardcoded footerColumns/footerLegalLinks — `section` is free text (e.g. "Help", "About", "legal") rather than a fixed enum since footer grouping is a merchandising decision, not a structural one.
 */
model FooterLink {
  id       String  @id @default(uuid())
  section  String
  label    String
  href     String
  position Int     @default(0)
  isActive Boolean @default(true) @map("is_active")

  @@map("footer_links")
}

// ─────────────────────────────────────────────────────────────────────────
// 3.10 Search — SEARCH_AND_FILTERS.md §8. No PII; query text + result count
// only, for popular-searches/zero-result reporting.
// ─────────────────────────────────────────────────────────────────────────

model SearchQueryLog {
  id          String @id @default(uuid())
  query       String
  resultCount Int    @map("result_count")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([query])
  @@map("search_query_logs")
}

// ─────────────────────────────────────────────────────────────────────────
// Cross-cutting — PAYMENT_ARCHITECTURE.md §3-4, SEO_ARCHITECTURE.md §6
// ─────────────────────────────────────────────────────────────────────────

model ProcessedWebhookEvent {
  id          String   @id @default(uuid())
  provider    String // e.g. "stripe"
  eventId     String   @unique @map("event_id")
  processedAt DateTime @default(now()) @map("processed_at")

  @@map("processed_webhook_events")
}

model Redirect {
  id              String @id @default(uuid())
  sourcePath      String @unique @map("source_path")
  destinationPath String @map("destination_path")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("redirects")
}
