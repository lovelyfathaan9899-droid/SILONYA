{
  "name": "@silonya/database",
  "version": "0.0.0",
  "private": true,
  "description": "Prisma schema, migrations, and typed database client (DATABASE_ARCHITECTURE.md) for SILONYA",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "prisma": {
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts"
  },
  "scripts": {
    "generate": "dotenv -e ../../.env -- prisma generate",
    "migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo node_modules generated"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@silonya/config": "workspace:*",
    "@types/node": "^22.10.0",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.17.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
