# SILONYA — Environment Variables
# Copy this file to .env (repo root) and fill in real values.
# Never commit .env — see PROJECT_RULES.md §8 and SECURITY_ARCHITECTURE.md §4.
# This file must be kept in sync with every variable actually consumed by
# the apps/packages below — an undocumented required var is a bug.

# ── Core ─────────────────────────────────────────────────────────────────
# NODE_ENV is deliberately not set here — Next.js/Node set it correctly per
# command (development for `next dev`, production for `next build`/`next
# start`). An explicit value in .env gets loaded by dotenv-cli (apps/*'s
# build/start/dev scripts) and overrides that, which silently breaks
# production builds (Next.js warns "non-standard NODE_ENV" and mis-renders
# the /404 and /500 shells). Don't add it back.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# ── Database (packages/database — DATABASE_ARCHITECTURE.md) ────────────────
# Neon Postgres connection string. Use a pooled connection for the app and
# a direct connection for migrations (TECH_STACK.md §2, §6).
DATABASE_URL="postgresql://user:password@localhost:5432/silonya?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/silonya?schema=public"

# Integration test database (TESTING_STRATEGY.md §4) — a separate database
# from the one above, never the dev/prod one. In CI this points at the
# postgres:16 service container (a single URL is fine there — set both vars
# to it); locally, point it at a dedicated database (e.g. a second database
# on the same Neon project — pooled connection for TEST_DATABASE_URL, direct
# for TEST_DIRECT_URL, same split as DATABASE_URL/DIRECT_URL above — or a
# local Postgres). `pnpm test:integration` runs `prisma migrate deploy`
# against TEST_DIRECT_URL first, then truncates all tables between tests —
# never point either at data you care about.
TEST_DATABASE_URL="postgresql://user:password@localhost:5432/silonya_test?schema=public"
TEST_DIRECT_URL="postgresql://user:password@localhost:5432/silonya_test?schema=public"

# ── Auth (packages/auth — AUTHENTICATION.md) ────────────────────────────────
# AUTH_SECRET signs/verifies access-token JWTs (packages/auth/src/tokens.ts).
# Generate one with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-real-32-byte-random-secret"

# Local-dev-only super_admin seed account (packages/database/prisma/seed.ts).
# Never set/used in production — production admins are provisioned by an
# existing admin (AUTHENTICATION.md §3).
ADMIN_SEED_EMAIL="admin@silonya.com"
ADMIN_SEED_PASSWORD="change-me-immediately"

# OAuth providers — not yet wired up (AUTHENTICATION.md §2.1 credentials-only
# for now); uncomment when Google/Apple sign-in is implemented.
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_APPLE_ID=
# AUTH_APPLE_SECRET=

# ── Payments (PAYMENT_ARCHITECTURE.md) ──────────────────────────────────────
# Test-mode keys only outside production (PAYMENT_ARCHITECTURE.md §8).
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=

# ── Search (SEARCH_AND_FILTERS.md) ──────────────────────────────────────────
# MEILISEARCH_HOST=
# MEILISEARCH_API_KEY=

# ── Cache / Queue (TECH_STACK.md §2, DEPLOYMENT.md §1) ──────────────────────
# REDIS_URL=

# ── Media (TECH_STACK.md §2) ─────────────────────────────────────────────
# Product image upload (ADMIN_PANEL.md §4.3 — signed direct-to-Cloudinary
# upload). getUploadSignature throws a clear error until these are set;
# nothing else in the app requires them.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Email (ORDER_MANAGEMENT.md §9) ───────────────────────────────────────
# RESEND_API_KEY=

# ── Monitoring & Analytics (DEPLOYMENT.md §6) ────────────────────────────
# SENTRY_DSN=
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=

# Variables above with an inactive "# " prefix are documented for the
# integrations described in the architecture docs but are not yet consumed
# by any code — they are activated (uncommented + required) as each
# integration is actually implemented in a later phase.
